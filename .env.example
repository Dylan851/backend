# Supabase Connection Pool (recommended for production)
# Format: postgresql+psycopg2://postgres.PROJECT_ID:PASSWORD@REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+psycopg2://postgres.[project-id]:[password]@aws-1-eu-west-1.pooler.supabase.com:6543/postgres

# Supabase Direct Connection (for migrations, use with caution)
# Format: postgresql+psycopg2://postgres.PROJECT_ID:PASSWORD@REGION.pooler.supabase.com:5432/postgres
DIRECT_URL=postgresql+psycopg2://postgres.[project-id]:[password]@aws-1-eu-west-1.pooler.supabase.com:5432/postgres

# JWT Configuration
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=10080
GOOGLE_CLIENT_IDS=your-web-client-id.apps.googleusercontent.com,your-android-client-id.apps.googleusercontent.com

# CORS Origins (add your Flutter app URL here)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8081

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
FRONTEND_URL=http://localhost:8080
